{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JoyYoungAI/EnterOcto/schemas/evidence-manifest.schema.json",
  "title": "EnterOcto Evidence Manifest",
  "description": "Integrity and provenance metadata for an EnterOcto evidence case.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "created_at",
    "mode",
    "status",
    "source_event",
    "capture",
    "analysis",
    "environment",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "case_id": {
      "type": "string",
      "pattern": "^(?!.*\\.\\.)[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": [
        "dry-run",
        "capture"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "completed",
        "failed"
      ]
    },
    "source_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "status",
        "interface",
        "host",
        "port",
        "duration_seconds",
        "max_kilobytes",
        "filter",
        "command",
        "started_at",
        "finished_at",
        "return_code",
        "error"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "completed",
            "failed"
          ]
        },
        "interface": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "duration_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "max_kilobytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10485760
        },
        "filter": {
          "type": "string"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "finished_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "return_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested",
        "tool_available",
        "status",
        "return_code",
        "started_at",
        "finished_at",
        "error",
        "artifacts"
      ],
      "properties": {
        "requested": {
          "type": "boolean"
        },
        "tool_available": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "not-requested",
            "tool-unavailable",
            "planned",
            "completed",
            "failed",
            "timeout"
          ]
        },
        "return_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "finished_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hostname",
        "python_version",
        "operator",
        "tools"
      ],
      "properties": {
        "hostname": {
          "type": "string"
        },
        "python_version": {
          "type": "string"
        },
        "operator": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "username",
            "uid",
            "gid"
          ],
          "properties": {
            "username": {
              "type": "string"
            },
            "uid": {
              "type": "integer",
              "minimum": 0
            },
            "gid": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "tools": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "dumpcap",
            "tshark"
          ],
          "properties": {
            "dumpcap": {
              "type": [
                "string",
                "null"
              ]
            },
            "tshark": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "media_type",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
